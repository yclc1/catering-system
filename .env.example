# Database Configuration
# 本地 PostgreSQL 示例
DATABASE_URL=postgresql+asyncpg://catering_user:your_password@localhost/catering_db

# 或使用云数据库（如阿里云 RDS）
# DATABASE_URL=postgresql+asyncpg://username:password@rm-xxxxx.mysql.rds.aliyuncs.com:5432/catering_db

# Security
SECRET_KEY=your_secret_key_here_use_openssl_rand_hex_32

# Application
DEBUG=False
